{
  "name": "ecommerce-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Advanced e-commerce platform (Amazon-like) — MERN + Next.js",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "pnpm --filter @ecommerce/server dev",
    "dev:client": "pnpm --filter @ecommerce/client dev",
    "build": "pnpm --filter @ecommerce/shared build && pnpm --filter @ecommerce/server build && pnpm --filter @ecommerce/client build",
    "build:shared": "pnpm --filter @ecommerce/shared build",
    "build:server": "pnpm --filter @ecommerce/server build",
    "build:client": "pnpm --filter @ecommerce/client build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "pnpm -r test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
